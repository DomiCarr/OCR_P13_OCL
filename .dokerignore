# ---------------------------------------------------------
# Python cache files
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ---------------------------------------------------------
# Virtual environments (not needed inside container)
# ---------------------------------------------------------
env/
venv/
.venv/

# ---------------------------------------------------------
# Git files (not needed for container build)
# ---------------------------------------------------------
.git
.gitignore

# ---------------------------------------------------------
# Test artifacts
# ---------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ---------------------------------------------------------
# Development tools
# ---------------------------------------------------------
.vscode/
.idea/

# ---------------------------------------------------------
# OS files
# ---------------------------------------------------------
.DS_Store

# ---------------------------------------------------------
# Environment variables (handled at runtime)
# ---------------------------------------------------------
.env
.env.*

# ---------------------------------------------------------
# Local databases
# ---------------------------------------------------------
*.sqlite3
*.db

# ---------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------
build/
dist/
*.egg-info/

# ---------------------------------------------------------
# Documentation build output
# ---------------------------------------------------------
docs/_build/
doc/_build/

# ---------------------------------------------------------
# Local development utilities
# ---------------------------------------------------------
_dev_utils/